{
  "name": "med-ease",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "preinstall": "node scripts/preinstall.cjs",
    "dev": "pnpm --filter @workspace/medease run dev",
    "dev:api": "pnpm --filter @medease/api run dev:stable",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:libs": "pnpm -r --filter \"./packages/**\" --filter \"./lib/**\" --if-present run build",
    "build:web": "pnpm --filter @workspace/medease run build",
    "typecheck:libs": "tsc --build",
    "pretypecheck": "pnpm prisma:validate && pnpm prisma:generate",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./apps/**\" --filter \"./packages/**\" --filter \"./database\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:validate": "pnpm --filter @medease/database run validate",
    "prisma:generate": "pnpm --filter @medease/database run generate",
    "prisma:format": "pnpm --filter @medease/database run format",
    "prisma:migrate:deploy": "pnpm --filter @medease/database run migrate:deploy",
    "prisma:migrate:dev": "pnpm --filter @medease/database run migrate:dev",
    "prisma:migrate:status": "pnpm --filter @medease/database run migrate:status",
    "prisma:seed": "pnpm --filter @medease/database run seed",
    "test": "pnpm --filter @medease/queue run test && pnpm --filter @medease/auth run test",
    "test:coverage": "node scripts/ci/verify-coverage.mjs",
    "ci:smoke": "node scripts/ci/run-smoke-ci.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}

# Med-ease local infrastructure — copy to .env and adjust if needed
# Usage (from docker/): cp .env.example .env && docker compose up -d

COMPOSE_PROJECT_NAME=medease

# PostgreSQL
POSTGRES_USER=medease
POSTGRES_PASSWORD=medease_dev_password
POSTGRES_DB=medease
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=medease
MINIO_ROOT_PASSWORD=medease_minio_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_DOCUMENTS=medease-documents
MINIO_BUCKET_EXPORTS=medease-exports

# OpenSearch
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# pgAdmin (development only)
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@medease.local
PGADMIN_DEFAULT_PASSWORD=medease_pgadmin_dev

# API & Worker
API_PORT=3000
WORKER_PORT=3001
WORKER_QUEUE_NAME=medease-health-check

# Authentication (E2-01)
JWT_SECRET=dev-only-secret-minimum-thirty-two-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_REMEMBER_EXPIRY=30d
AUTH_COOKIE_SECURE=false

# Internal service URLs (used inside Docker network)
DATABASE_URL=postgresql://medease:medease_dev_password@postgres:5432/medease
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=medease
MINIO_SECRET_KEY=medease_minio_dev
OPENSEARCH_URL=http://opensearch:9200

# API platform (E1-02)
API_PREFIX=api
CORS_ORIGIN=*
HELMET_ENABLED=true
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM=noreply@medease.local

# Observability (E1-07)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=medease_grafana_dev
LOKI_PORT=3100
TEMPO_PORT=3200
GIT_COMMIT=local
BUILD_TIMESTAMP=
APP_VERSION=0.0.0

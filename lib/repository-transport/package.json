{
  "name": "@workspace/repository-transport",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./errors": {
      "types": "./dist/errors.d.ts",
      "require": "./dist/errors.js",
      "default": "./dist/errors.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:errors",
    "build:errors": "tsc -p tsconfig.errors.json",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/api-client-react": "workspace:*"
  },
  "devDependencies": {
    "tsx": "catalog:"
  }
}

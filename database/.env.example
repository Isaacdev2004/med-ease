# Supabase session pooler (recommended when direct db.* is unreachable — e.g. IPv6-only DNS)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# Direct connection (port 5432) — URL-encode special chars in password (@ %40, # %23, $ %24)
# DATABASE_URL=postgresql://postgres:[URL-ENCODED-PASSWORD]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# SUPABASE_URL=https://[project-ref].supabase.co

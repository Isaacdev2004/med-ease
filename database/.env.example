# Prisma CLI + seed scripts load this file via database/load-env.ts

# Session pooler (recommended for runtime queries and seed over remote networks)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

# Direct connection — preferred for `pnpm prisma:migrate:deploy`
# URL-encode special characters in password (@ %40, # %23, $ %24)
DIRECT_URL=postgresql://postgres:[URL-ENCODED-PASSWORD]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# Windows / IPv6 fallback: if migrate fails with P1001 to db.*.supabase.co, set
# DIRECT_URL to the same session pooler URI as DATABASE_URL (port 5432, not 6543).

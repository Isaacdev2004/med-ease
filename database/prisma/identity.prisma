// ─────────────────────────────────────────────────────────────────────────────
// Identity schema — authentication & sessions (E2-01)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id               String       @id @db.Uuid
  tenantId         String       @map("tenant_id") @db.Uuid
  organizationId   String       @map("organization_id") @db.Uuid
  email            String
  passwordHash     String       @map("password_hash")
  fullName         String       @map("full_name")
  role             IdentityRole
  status           UserStatus   @default(active)
  locale           String       @default("en-US")
  timezone         String       @default("UTC")
  avatarUrl        String?      @map("avatar_url")
  facilityId       String?      @map("facility_id") @db.Uuid
  mfaEnabled       Boolean      @default(false) @map("mfa_enabled")
  failedLoginCount Int          @default(0) @map("failed_login_count")
  lockedUntil      DateTime?    @map("locked_until")
  lastLoginAt      DateTime?    @map("last_login_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  sessions     UserSession[]
  roleAssignments UserRoleAssignment[]
  mfaDevices   MfaDevice[]
  trustedDevices TrustedDevice[]

  @@unique([tenantId, email])
  @@index([organizationId])
  @@map("users")
  @@schema("identity")
}

model UserSession {
  id              String        @id @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  deviceId        String?       @map("device_id")
  ipAddress       String?       @map("ip_address")
  userAgent       String?       @map("user_agent")
  status          SessionStatus @default(active)
  refreshFamilyId String        @map("refresh_family_id") @db.Uuid
  rememberMe      Boolean       @default(false) @map("remember_me")
  startedAt       DateTime      @default(now()) @map("started_at")
  lastActivityAt  DateTime      @default(now()) @map("last_activity_at")
  expiresAt       DateTime      @map("expires_at")
  revokedAt       DateTime?     @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([refreshFamilyId])
  @@map("user_sessions")
  @@schema("identity")
}

model LoginAttempt {
  id          String   @id @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  email       String
  success     Boolean
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  reason      String?
  attemptedAt DateTime @default(now()) @map("attempted_at")

  @@index([email, attemptedAt(sort: Desc)])
  @@map("login_attempts")
  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// Shared enums (Appendix A sample + platform foundation)
// Maps to PostgreSQL native enums via @@schema directive.
// ─────────────────────────────────────────────────────────────────────────────

enum TenantStatus {
  active
  suspended
  provisioning
  decommissioned

  @@map("tenant_status")
  @@schema("core")
}

enum SubscriptionTier {
  starter
  professional
  enterprise

  @@map("subscription_tier")
  @@schema("core")
}

enum UserStatus {
  active
  inactive
  locked
  pending

  @@map("user_status")
  @@schema("identity")
}

enum IdentityRole {
  platform_admin
  facility_admin
  physician
  pharmacist
  transport_dispatcher
  patient

  @@map("identity_role")
  @@schema("identity")
}

enum SessionStatus {
  active
  revoked
  expired

  @@map("session_status")
  @@schema("identity")
}


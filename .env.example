# Copy to .env at repo root (API loads ../../.env from apps/api)

# Supabase — see database/.env.example for connection string formats
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_URL=https://[project-ref].supabase.co

# Local Docker (pnpm docker:up) — use localhost when API runs on host
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=medease
MINIO_SECRET_KEY=medease_minio_dev
MINIO_BUCKET_DOCUMENTS=medease-documents
MINIO_BUCKET_EXPORTS=medease-exports
OPENSEARCH_URL=http://localhost:9200

JWT_SECRET=dev-only-secret-minimum-thirty-two-characters-long
AUTH_COOKIE_SECURE=false
PORT=3000
WORKER_QUEUE_NAME=medease-health-check
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@medease.local

# Frontend dev server
# PORT=5173

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build:libs && pnpm build:web",
  "devCommand": "pnpm --filter @workspace/medease run dev",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "artifacts/medease/dist",
  "framework": null,
  "rewrites": [{ "source": "/((?!assets/).*)", "destination": "/index.html" }]
}

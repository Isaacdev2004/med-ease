{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "types": ["node"],
    "sourceMap": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@workspace/repository-transport/errors": [
        "../../lib/repository-transport/dist/errors"
      ]
    }
  },
  "include": ["src/**/*.ts"]
}
